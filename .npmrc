# Untitled UI PRO icons registry.
# No secret here: the token is read from the UNTITLEDUI_PRO_TOKEN env var.
#   - Locally it resolves from your ~/.npmrc token line (same host).
#   - On Netlify it resolves from the UNTITLEDUI_PRO_TOKEN build env var.
@untitledui-pro:registry=https://pkg.untitledui.com
//pkg.untitledui.com/:_authToken=${UNTITLEDUI_PRO_TOKEN}
